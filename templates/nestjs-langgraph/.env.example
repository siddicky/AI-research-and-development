# OpenAI API Key (required for LangGraph agent)
OPENAI_API_KEY=your-api-key-here

# Application
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5434
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=db-template

# Prisma Database URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/db-template?schema=public"

# Test Database Configuration
TEST_DB_HOST=localhost
TEST_DB_PORT=5435
TEST_DB_USERNAME=postgres
TEST_DB_PASSWORD=postgres
TEST_DB_NAME=db-template-test

# Test Database URL for Prisma
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5435/db-template-test?schema=public"

# Ollama Configuration (optional, for local AI models)
OLLAMA_HOST=http://localhost:11434
