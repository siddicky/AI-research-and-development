# OpenAI API Key (required for LangGraph agent)
OPENAI_API_KEY=your-api-key-here

# Application
PORT=3000
NODE_ENV=development

# Database Configuration (MySQL)
DATABASE_URL="mysql://mysql:mysql@localhost:3306/db_template"

# Test Database Configuration (MySQL)
TEST_DATABASE_URL="mysql://mysql:mysql@localhost:3307/db_template_test"

# Ollama Configuration (optional, for local AI models)
OLLAMA_HOST=http://localhost:11434
